# --- Secrets: never commit these ---
# (a bare `secrets/` would ignore the .devcontainer/secrets DIRECTORY
# itself, which defeats the README re-include below -- git cannot
# re-include a file whose parent directory is excluded)
.devcontainer/secrets/*
!.devcontainer/secrets/README.md
/secrets/
*.key
.env
.env.*

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
dist/
build/

# --- Runtime output ---
logs/
evals/runs/
